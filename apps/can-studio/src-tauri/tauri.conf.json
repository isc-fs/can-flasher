{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ISC CAN Studio",
  "version": "0.3.2",
  "identifier": "com.iscracingteam.can-studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ISC CAN Studio",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026 ISC Racing Team",
    "shortDescription": "Flash, monitor, and debug CAN messages on STM32 ECUs.",
    "longDescription": "ISC CAN Studio is the desktop companion to the can-flasher CLI: a single window that wraps firmware flashing, live device discovery, fault-code diagnostics, and CAN bus monitoring for the ISC racing team's Formula Student ECUs. Cross-platform native via Tauri 2.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
